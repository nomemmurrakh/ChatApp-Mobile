{
  "expo": {
    "name": "chatapp",
    "slug": "chatapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chatapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/images/ios-icon.png",
      "config": {
        "usesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.nomemmurrakh.chatapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "allowBackup": true,
      "package": "com.nomemmurrakh.chatapp",
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#9d4edd"
        }
      ],
      [
        "react-native-edge-to-edge",
        {
          "android": {
            "enforceNavigationBarContrast": false
          }
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Inter_18pt-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-Regular.ttf",
                    "weight": 400
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/Inter_18pt-Bold.ttf",
              "./assets/fonts/Inter_18pt-SemiBold.ttf",
              "./assets/fonts/Inter_18pt-Medium.ttf",
              "./assets/fonts/Inter_18pt-Regular.ttf"
            ]
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
